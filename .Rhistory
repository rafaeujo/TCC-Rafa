year_start = i,
month_start = 1,
year_end = i,
month_end = 1,
uf = "all",
information_system = "SIM-DO",
stop_on_error = FALSE,
timeout = 1000,
track_source = FALSE
)
dt_proc[[as.character(i)]] <- process_sim(
data = dt_brut[[as.character(i)]]
)
}
